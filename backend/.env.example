# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://postgres:your_password@localhost:5432/student_management

# Redis cache
REDIS_URL=redis://localhost:6379/0

# Logging and cache settings
LOG_LEVEL=INFO
CACHE_DEFAULT_TTL_SECONDS=60

# App metadata
APP_NAME=Student Management API

# JWT / auth (generate a strong random string for production)
SECRET_KEY=long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_ALGORITHM=HS256
BACK_END_ALLOWED_ORIGINS=http://localhost:3000


# Optional seed variables (used by scripts/seed_data.py)
SEED_USER_EMAIL=student@example.com
SEED_USER_PASSWORD=password
SEED_USER_ROLE=student
SEED_STUDENT_NAME=Sample Student
SEED_STUDENT_GPA=3.5
SEED_STUDENT_DEPARTMENT=Computer Science
